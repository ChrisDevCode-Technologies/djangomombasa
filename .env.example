# Django settings module (config.settings.dev or config.settings.prod)
# Default: dev for manage.py, prod for wsgi/asgi
DJANGO_SETTINGS_MODULE=config.settings.dev

# === Development settings (config.settings.dev) ===
# No environment variables required - sensible defaults are used

# === Production settings (config.settings.prod) ===
# All of these are REQUIRED when using prod settings:

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=djangomombasa.com,www.djangomombasa.com

# Comma-separated list of trusted origins (include scheme)
CSRF_TRUSTED_ORIGINS=https://djangomombasa.com,https://www.djangomombasa.com

# Email (Resend SMTP — https://resend.com)
# Required: API key used as the SMTP password
RESEND_API_KEY=your-resend-api-key-here
# Optional overrides (sensible defaults are set in base.py):
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=resend
# DEFAULT_FROM_EMAIL=Django Mombasa <info@djangomombasa.org>

# Absolute base URL of the public site, used in outbound email links.
SITE_URL=https://djangomombasa.org

# === Database (PostgreSQL — used in production / Docker) ===
DB_NAME=djangomombasa
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=db
DB_PORT=5432

# === Telegram Bot ===
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Base URL of the Django server (the bot calls the eligibility API)
ELIGIBILITY_API_URL=http://localhost:8000

# === Deployment ===
# Static files are served via WhiteNoise (automatic compression + caching)
# Before deploying, run: python manage.py collectstatic --noinput
# The Procfile includes this in the release phase for PaaS deployments
#
# Docker:
#   docker compose up --build -d
#   docker compose exec web python manage.py createsuperuser
